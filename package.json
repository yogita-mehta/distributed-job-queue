    "load-test": "node scripts/loadTest.js"
  },
  "keywords": ["job-queue", "redis", "distributed-systems", "backend"],
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "uuid": "^9.0.1"
  }
}
